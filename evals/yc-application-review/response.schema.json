{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "company_description",
    "evidence_ledger",
    "signal_split",
    "interview_likelihood",
    "verdict",
    "score_caveat",
    "score_movers",
    "positive_evidence",
    "risks",
    "missing_specifics",
    "improvements",
    "source_grounding",
    "myth_checks",
    "context_probes",
    "evidence_vs_inference",
    "non_ghostwriting_check"
  ],
  "properties": {
    "company_description": {
      "type": "string",
      "minLength": 1
    },
    "interview_likelihood": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "verdict": {
      "type": "string",
      "enum": ["likely", "borderline", "unlikely"]
    },
    "score_caveat": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product",
        "user",
        "proof_users_care",
        "progress",
        "founder_market_fit",
        "unique_insight",
        "market_path",
        "distribution",
        "competitive_context"
      ],
      "properties": {
        "product": { "type": "string", "minLength": 1 },
        "user": { "type": "string", "minLength": 1 },
        "proof_users_care": { "type": "string", "minLength": 1 },
        "progress": { "type": "string", "minLength": 1 },
        "founder_market_fit": { "type": "string", "minLength": 1 },
        "unique_insight": { "type": "string", "minLength": 1 },
        "market_path": { "type": "string", "minLength": 1 },
        "distribution": { "type": "string", "minLength": 1 },
        "competitive_context": { "type": "string", "minLength": 1 }
      }
    },
    "signal_split": {
      "type": "object",
      "additionalProperties": false,
      "required": ["founder_signal", "company_signal", "application_signal", "main_gap"],
      "properties": {
        "founder_signal": { "type": "string", "minLength": 1 },
        "company_signal": { "type": "string", "minLength": 1 },
        "application_signal": { "type": "string", "minLength": 1 },
        "main_gap": { "type": "string", "minLength": 1 }
      }
    },
    "score_movers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["could_move_up", "could_move_down"],
      "properties": {
        "could_move_up": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "could_move_down": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "positive_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_specifics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "improvements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_grounding": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_path", "source_class", "relevance"],
        "properties": {
          "source_path": { "type": "string", "minLength": 1 },
          "source_class": {
            "type": "string",
            "enum": ["official_yc", "yc_affiliated", "public_example", "founder_story", "yc_directory", "rfs", "external_context", "skill_reference", "inference"]
          },
          "relevance": { "type": "string", "minLength": 1 }
        }
      }
    },
    "myth_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["myth", "correction", "source_path", "applied_to_application"],
        "properties": {
          "myth": { "type": "string", "minLength": 1 },
          "correction": { "type": "string", "minLength": 1 },
          "source_path": { "type": "string", "minLength": 1 },
          "applied_to_application": { "type": "string", "minLength": 1 }
        }
      }
    },
    "context_probes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["angle", "why_it_matters", "next_question"],
        "properties": {
          "angle": { "type": "string", "minLength": 1 },
          "why_it_matters": { "type": "string", "minLength": 1 },
          "next_question": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence_vs_inference": {
      "type": "string",
      "minLength": 1
    },
    "non_ghostwriting_check": {
      "type": "boolean"
    }
  }
}
